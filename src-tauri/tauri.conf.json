{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "flapp",
  "version": "0.1.0",
  "identifier": "com.flapp.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "flapp",
        "width": 1280,
        "height": 832,
        "minWidth": 1040,
        "minHeight": 680,
        "dragDropEnabled": true,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Music",
    "shortDescription": "Менеджер сэмплов для битмейкеров",
    "longDescription": "Автоматический сбор, анализ, сортировка и управление звуками из музыкальных проектов и архивов.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/flapp-core"],
    "resources": []
  }
}
